rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== ownerNotes: للمالك فقط =====
    match /ownerNotes/{doc} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'f5h5d_q8@hotmail.com';
    }

    // ===== editHistory: الكل يقرأ ويضيف، التعديل/الحذف للمالك فقط =====
    match /editHistory/{doc} {
      allow read, create: if true;
      allow update, delete: if request.auth != null
        && request.auth.token.email == 'f5h5d_q8@hotmail.com';
    }

    // ===== كل شي ثاني مفتوح للكل (موقع داخلي بسيط) =====
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
