rules_version = '2';
  service cloud.firestore {
    match /databases/{database}/documents {
      function isOwner() {
        return request.auth != null && request.auth.token.email == 'f5h5d_q8@hotmail.com';
      }
      function isAuth() {
        return request.auth != null;
      }

      // قراءة عامة لمن سجّل دخول، الكتابة محصورة على الإيميلات المعتمدة
      match /drivers/{doc} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
      match /driverPayments/{doc} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
      match /expenses/{doc} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
      match /revenues/{doc} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
      match /editHistory/{doc} {
        allow read: if isAuth();
        // المحاسب يقدر يكتب لكن ما يقدر يحذف من سجل التعديلات
        allow create: if isAuth();
        allow update, delete: if isOwner();
      }
      match /archivedDrivers/{doc} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
      match /cars/{doc} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
      // أي مجموعة جديدة - افتراضياً للمالك فقط
      match /{document=**} {
        allow read: if isAuth();
        allow write: if isOwner();
      }
    }
  }
  